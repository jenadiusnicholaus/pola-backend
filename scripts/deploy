#!/bin/bash

# ==========================================
# POLA Backend Deployment Script - Simple Version
# ==========================================
# Works with external VPS nginx and just docker-compose.prod.yml
# ==========================================

set -e  # Exit on any error

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Configuration
PROJECT_NAME="pola-backend"
DOMAIN="${DOMAIN:-yourdomain.com}"
EMAIL="${EMAIL:-admin@yourdomain.com}"
ENV_FILE="${ENV_FILE:-.env}"
COMPOSE_FILE="docker-compose.prod.yml"

# Functions
log_info() {
    echo -e "${BLUE}[INFO]${NC} $1"
}

log_success() {
    echo -e "${GREEN}[SUCCESS]${NC} $1"
}

log_warning() {
    echo -e "${YELLOW}[WARNING]${NC} $1"
}

log_error() {
    echo -e "${RED}[ERROR]${NC} $1"
}

# Check dependencies
check_dependencies() {
    log_info "Checking dependencies..."
    
    local deps=("docker" "git" "curl")
    for dep in "${deps[@]}"; do
        if ! command -v $dep &> /dev/null; then
            log_error "$dep is not installed. Please install it first."
            exit 1
        fi
    done
    
    log_success "All dependencies are installed"
}

# Setup environment
setup_environment() {
    log_info "Setting up environment..."
    
    if [[ ! -f "$ENV_FILE" ]]; then
        log_warning "$ENV_FILE not found. Creating from template..."
        if [[ -f ".env.example" ]]; then
            cp .env.example "$ENV_FILE"
            log_info "Please edit $ENV_FILE with your production settings"
            log_info "Required variables: SECRET_KEY, DB_NAME, DB_USER, DB_PASSWORD, DOMAIN, EMAIL"
            read -p "Press Enter after editing the environment file..."
        else
            log_error "No .env.production.example found. Please create $ENV_FILE manually"
            exit 1
        fi
    fi
    
    # Source environment file
    set -a
    source "$ENV_FILE"
    set +a
    
    # Validate required environment variables
    local required_vars=("SECRET_KEY" "DB_NAME" "DB_USER" "DB_PASSWORD" "DOMAIN")
    for var in "${required_vars[@]}"; do
        if [[ -z "${!var}" ]]; then
            log_error "Environment variable $var is not set in $ENV_FILE"
            exit 1
        fi
    done
    
    log_success "Environment setup complete"
}

# Create necessary directories
create_directories() {
    log_info "Creating necessary directories..."
    
    mkdir -p logs
    mkdir -p backups
    mkdir -p static
    mkdir -p media
    
    log_success "Directories created"
}

# Stop existing services
stop_services() {
    log_info "Stopping existing services..."
    
    sudo docker compose -f $COMPOSE_FILE down --remove-orphans || true
    
    log_success "Services stopped"
}

# Build and start services
build_and_start() {
    log_info "Building and starting services..."
    
    # Build images
    sudo docker compose -f $COMPOSE_FILE build
    
    # Start services
    sudo docker compose -f $COMPOSE_FILE up -d
    
    log_success "Services started"
}

# Wait for database to be ready
wait_for_database() {
    log_info "Waiting for database to be ready..."
    
    local max_attempts=30
    local attempt=1
    
    while [[ $attempt -le $max_attempts ]]; do
        if sudo docker compose -f $COMPOSE_FILE exec -T db pg_isready -U "$DB_USER" -d "$DB_NAME" &>/dev/null; then
            log_success "Database is ready"
            return 0
        fi
        
        log_info "Attempt $attempt/$max_attempts: Database not ready, waiting..."
        sleep 2
        ((attempt++))
    done
    
    log_error "Database failed to start within expected time"
    exit 1
}

# Run database migrations
run_migrations() {
    log_info "Running database migrations..."
    
    sudo docker compose -f $COMPOSE_FILE exec -T web python manage.py migrate --noinput
    
    log_success "Migrations completed"
}

# Collect static files
collect_static() {
    log_info "Collecting static files..."
    
    sudo docker compose -f $COMPOSE_FILE exec -T web python manage.py collectstatic --noinput --clear
    
    log_success "Static files collected"
}

# Create superuser (optional)
create_superuser() {
    if [[ "$CREATE_SUPERUSER" == "true" ]]; then
        log_info "Creating superuser..."
        
        sudo docker compose -f $COMPOSE_FILE exec -T web python manage.py createsuperuser --noinput || {
            log_warning "Superuser creation failed or already exists"
        }
        
        log_success "Superuser creation attempted"
    fi
}

# Generate nginx configuration
generate_nginx_config() {
    log_info "Generating nginx configuration..."
    
    local nginx_config="nginx-generated.conf"
    cat > "$nginx_config" << EOF
# ==========================================
# POLA Backend Nginx Configuration
# Generated: $(date)
# Domain: $DOMAIN
# ==========================================

# Upstream Django application (Docker containers)
upstream pola_backend {
    server 127.0.0.1:8000;
    keepalive 32;
}

# Rate limiting zones
limit_req_zone \$binary_remote_addr zone=api_limit:10m rate=10r/s;
limit_conn_zone \$binary_remote_addr zone=conn_limit:10m;

# HTTP Server - Redirect to HTTPS
server {
    listen 80;
    server_name $DOMAIN www.$DOMAIN;

    # Allow certbot challenges for SSL setup
    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
        allow all;
    }

    # Redirect all other traffic to HTTPS
    location / {
        return 301 https://\$host\$request_uri;
    }
}

# HTTPS Server
server {
    listen 443 ssl http2;
    server_name $DOMAIN www.$DOMAIN;

    # SSL Configuration
    ssl_certificate /etc/letsencrypt/live/$DOMAIN/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/$DOMAIN/privkey.pem;
    ssl_session_timeout 1d;
    ssl_session_cache shared:SSL:50m;
    ssl_session_tickets off;

    # Modern SSL configuration
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384;
    ssl_prefer_server_ciphers off;

    # HSTS
    add_header Strict-Transport-Security "max-age=63072000" always;

    # Static files (served from Docker volume)
    location /static/ {
        alias $(pwd)/static/;
        expires 30d;
        add_header Cache-Control "public, immutable";
        access_log off;
    }

    # Media files (served from Docker volume)
    location /media/ {
        alias $(pwd)/media/;
        expires 7d;
        add_header Cache-Control "public";
    }

    # API endpoints with rate limiting
    location /api/ {
        limit_req zone=api_limit burst=20 nodelay;
        limit_conn conn_limit 10;

        proxy_pass http://pola_backend;
        proxy_http_version 1.1;
        proxy_set_header Host \$http_host;
        proxy_set_header X-Real-IP \$remote_addr;
        proxy_set_header X-Forwarded-For \$proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto \$scheme;
        proxy_set_header Connection "";
        proxy_connect_timeout 60s;
        proxy_send_timeout 60s;
        proxy_read_timeout 60s;
    }

    # Admin and other Django URLs
    location / {
        proxy_pass http://pola_backend;
        proxy_http_version 1.1;
        proxy_set_header Host \$http_host;
        proxy_set_header X-Real-IP \$remote_addr;
        proxy_set_header X-Forwarded-For \$proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto \$scheme;
        proxy_set_header Connection "";
    }

    # Health check endpoint
    location /health {
        access_log off;
        return 200 "healthy\n";
        add_header Content-Type text/plain;
    }
}
EOF

    log_success "Nginx configuration generated: $nginx_config"
    log_info "Copy this file to your VPS nginx configuration directory"
    log_info "Example: sudo cp $nginx_config /etc/nginx/sites-available/pola-backend"
}

# Health check
health_check() {
    log_info "Performing health checks..."
    
    # Check if containers are running
    local containers=("db" "web")
    for container in "${containers[@]}"; do
        if sudo docker compose -f $COMPOSE_FILE ps | grep -q "$container.*Up"; then
            log_success "$container container is running"
        else
            log_error "$container container is not running"
            return 1
        fi
    done
    
    # Check web application health
    local max_attempts=10
    local attempt=1
    
    while [[ $attempt -le $max_attempts ]]; do
        if curl -f http://localhost:8000/health &>/dev/null; then
            log_success "Web application is responding"
            break
        fi
        
        if [[ $attempt -eq $max_attempts ]]; then
            log_error "Web application health check failed"
            return 1
        fi
        
        log_info "Health check attempt $attempt/$max_attempts..."
        sleep 5
        ((attempt++))
    done
    
    log_success "All health checks passed"
}

# Show deployment info
show_deployment_info() {
    log_success "Deployment completed successfully!"
    echo
    echo "========================================="
    echo "Deployment Information"
    echo "========================================="
    echo "Environment: Production"
    echo "Docker Compose: $COMPOSE_FILE"
    echo
    echo "Services Status:"
    sudo docker compose -f $COMPOSE_FILE ps
    echo
    echo "Useful Commands:"
    echo "  View logs: sudo docker compose -f $COMPOSE_FILE logs -f"
    echo "  Stop services: sudo docker compose -f $COMPOSE_FILE down"
    echo "  Restart services: sudo docker compose -f $COMPOSE_FILE restart"
    echo "  Access container: sudo docker compose -f $COMPOSE_FILE exec web bash"
    echo
    echo "Next Steps:"
    echo "1. Setup nginx manually if needed"
    echo "2. Test application: curl http://localhost:8000/health"
    echo "========================================="
}

# Cleanup function
cleanup() {
    if [[ $? -ne 0 ]]; then
        log_error "Deployment failed. Cleaning up..."
        sudo docker compose -f $COMPOSE_FILE down --remove-orphans || true
    fi
}

# Main deployment function
main() {
    log_info "Starting POLA Backend deployment..."
    
    # Set up cleanup trap
    trap cleanup EXIT
    
    # Run deployment steps
    check_dependencies
    setup_environment
    create_directories
    stop_services
    build_and_start
    wait_for_database
    run_migrations
    collect_static
    create_superuser
    health_check
    show_deployment_info
    
    log_success "Deployment completed successfully!"
}

# Parse command line arguments
case "${1:-deploy}" in
    "deploy")
        main
        ;;
    "stop")
        log_info "Stopping services..."
        sudo docker compose -f $COMPOSE_FILE down --remove-orphans
        log_success "Services stopped"
        ;;
    "restart")
        log_info "Restarting services..."
        sudo docker compose -f $COMPOSE_FILE restart
        log_success "Services restarted"
        ;;
    "logs")
        sudo docker compose -f $COMPOSE_FILE logs -f
        ;;
    "status")
        sudo docker compose -f $COMPOSE_FILE ps
        ;;
    "migrate")
        log_info "Running migrations..."
        sudo docker compose -f $COMPOSE_FILE exec -T web python manage.py migrate
        ;;
    "collectstatic")
        log_info "Collecting static files..."
        sudo docker compose -f $COMPOSE_FILE exec -T web python manage.py collectstatic --noinput
        ;;
    "nginx-config")
        generate_nginx_config
        ;;
    "backup")
        log_info "Creating database backup..."
        ./db_backup.sh
        ;;
    "seed")
        log_info "Seeding production data..."
        sudo docker compose -f $COMPOSE_FILE exec -T web python seed_production.py
        ;;
    "seed-auth")
        log_info "Seeding authentication data only..."
        sudo docker compose -f $COMPOSE_FILE exec -T web python manage.py seed_user_roles
        sudo docker compose -f $COMPOSE_FILE exec -T web python manage.py seed_regions_districts
        sudo docker compose -f $COMPOSE_FILE exec -T web python manage.py seed_specializations
        ;;
    "seed-subs")
        log_info "Seeding subscription data only..."
        sudo docker compose -f $COMPOSE_FILE exec -T web python manage.py seed_subscription_plans
        sudo docker compose -f $COMPOSE_FILE exec -T web python manage.py seed_consultants
        ;;
    "seed-bundles")
        log_info "Seeding call credit bundles..."
        sudo docker compose -f $COMPOSE_FILE exec -T web python manage.py create_call_credit_bundles
        sudo docker compose -f $COMPOSE_FILE exec -T web python manage.py create_initial_pricing
        sudo docker compose -f $COMPOSE_FILE exec -T web python manage.py update_bundle_descriptions
        ;;
    "seed-chapters")
        log_info "Seeding regional chapters..."
        sudo docker compose -f $COMPOSE_FILE exec -T web python manage.py seed_regional_chapters
        ;;
    "seed-all")
        log_info "Seeding all authentication data..."
        sudo docker compose -f $COMPOSE_FILE exec -T web python manage.py seed_all
        ;;
    "help"|"-h"|"--help")
        echo "Usage: $0 [COMMAND]"
        echo
        echo "Commands:"
        echo "  deploy         - Full deployment (default)"
        echo "  stop           - Stop all services"
        echo "  restart        - Restart all services"
        echo "  logs           - Show logs"
        echo "  status         - Show service status"
        echo "  migrate        - Run database migrations"
        echo "  collectstatic  - Collect static files"
        echo "  nginx-config   - Generate nginx configuration"
        echo "  backup         - Create database backup"
        echo "  seed           - Seed all production data"
        echo "  seed-auth      - Seed authentication data only"
        echo "  seed-subs      - Seed subscription data only"
        echo "  seed-bundles   - Seed call credit bundles only"
        echo "  seed-chapters  - Seed regional chapters only"
        echo "  seed-all       - Seed all authentication data"
        echo "  help           - Show this help message"
        echo
        echo "Files Used:"
        echo "  Docker Compose: $COMPOSE_FILE"
        echo "  Environment: $ENV_FILE"
        echo
        echo "Environment Variables:"
        echo "  DOMAIN         - Your domain name"
        echo "  EMAIL          - Email for SSL certificates"
        echo "  CREATE_SUPERUSER - Create superuser (true/false)"
        ;;
    *)
        log_error "Unknown command: $1"
        echo "Use '$0 help' for available commands"
        exit 1
        ;;
esac
