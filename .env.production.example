# ==========================================
# Docker Environment Variables - PRODUCTION
# ==========================================
# Copy this file to .env.production and fill in actual values
# NEVER commit .env.production to version control!
# Usage: docker-compose -f docker-compose.prod.yml --env-file .env.production up -d
# ==========================================

# Django Settings
# Generate a new secret key with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-production-secret-key-here-generate-a-new-one
DEBUG=False
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com,185.237.253.223

# Database Configuration
DB_NAME=pola_production
DB_USER=pola_prod_user
DB_PASSWORD=your-very-strong-database-password-here
DB_HOST=db
DB_PORT=5432
DB_TIMEZONE=Africa/Dar_es_Salaam

# API Configuration
API_VERSION=v1

# JWT Token Configuration (in minutes)
ACCESS_TOKEN_LIFETIME=30
REFRESH_TOKEN_LIFETIME=720

# CORS Configuration (specify your frontend domain)
CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com,https://app.yourdomain.com
CORS_ALLOW_ALL_ORIGINS=False

# CSRF Configuration
CSRF_TRUSTED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Security Settings (True for production)
CSRF_COOKIE_SECURE=True
SESSION_COOKIE_SECURE=True

# ==============================================================================
# AZAMPAY PAYMENT GATEWAY (Production)
# ==============================================================================
AZAM_PAY_APP_NAME=POLA
AZAM_PAY_CLIENT_ID=your-production-client-id
AZAM_PAY_CLIENT_SECRET=your-production-client-secret
AZAM_PAY_PRODUCTION=True
AZAM_PAY_MERCHANT_ACCOUNT=your-merchant-account
AZAM_PAY_WEBHOOK_URL=https://yourdomain.com/api/v1/subscriptions/webhooks/azampay/

# ==============================================================================
# SSL/TLS Configuration
# ==============================================================================
# Domain for SSL certificate (used by certbot)
DOMAIN=yourdomain.com
EMAIL=admin@yourdomain.com

# ==============================================================================
# DEPLOYMENT CONFIGURATION
# ==============================================================================
# Enable SSL certificates (true/false)
SSL_ENABLED=true

# Create superuser during deployment (true/false)
CREATE_SUPERUSER=false

# Deployment environment
DEPLOYMENT_ENV=production
